# =============================================================
# Plaid
# Get these from https://dashboard.plaid.com → Developers → Keys
# =============================================================
PLAID_CLIENT_ID=your_client_id
PLAID_SECRET=your_sandbox_secret
PLAID_ENV=sandbox                 # sandbox | development | production
PLAID_PRODUCTS=transactions       # comma-separated, e.g. transactions,auth
PLAID_COUNTRY_CODES=US            # comma-separated, e.g. US,CA
# PLAID_REDIRECT_URI=             # only needed for OAuth banks

# =============================================================
# Database (Postgres via Prisma)
# Supabase: Project Settings → Database → Connection string
#
# DATABASE_URL = pooled connection  (runtime queries)
#   Supabase: port 6543, add ?pgbouncer=true
# DIRECT_URL   = direct connection  (prisma migrate)
#   Supabase: port 5432
# =============================================================
DATABASE_URL=postgresql://user:password@host:6543/dbname?sslmode=require&pgbouncer=true
DIRECT_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# =============================================================
# App
# =============================================================
# Fixed UUID for the seeded dev user, used until real auth exists.
# Generate once and keep stable:
#   node -e "console.log(require('crypto').randomUUID())"
DEV_USER_ID=00000000-0000-0000-0000-000000000000

# Encryption key for Plaid access tokens at rest (AES-256-GCM).
# Must decode to exactly 32 bytes. Generate with:
#   openssl rand -base64 32
# WARNING: changing this makes all stored tokens undecryptable (re-link required).
# Use a different key per environment; never commit the real value.
ENCRYPTION_KEY=your_base64_32_byte_key
