// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid(7)) @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  email     String   @unique
  name      String?

  items    PlaidItem[]
  budgets  Budget[]
  goals    Goal[]
}

model PlaidItem {
  id      String  @id @default(uuid(7)) @db.Uuid
  userId  String  @db.Uuid
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  plaidItemId  String    @unique          // Plaid's item_id
  accessToken  String                     // ENCRYPT at rest (see note)
  institutionId   String?
  institutionName String?

  // transactionsSync pagination cursor - null until first successful sync
  syncCursor   String?
  status       String    @default("active") // active | login_required | error
  lastSyncedAt DateTime?

  // Whether Plaid Investments consent has been requested for this item. New
  // items request it at link time; items linked before consent was added stay
  // false until taken through update mode (see create_update_link_token).
  investmentsConsented Boolean @default(false)

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  accounts     Account[]

  @@index([userId])
}


model Account {
  id              String    @id @default(uuid(7)) @db.Uuid
  itemId          String    @db.Uuid
  item            PlaidItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  plaidAccountId  String    @unique        // Plaid's account_id
  name            String
  officialName    String?
  mask            String?                  // last 4 digits
  type            String                   // depository | credit | loan | investment
  subtype         String?                  // checking | savings | credit card ...

  // latest balance snapshot from Plaid
  currentBalance   Decimal? @db.Decimal(14, 2)
  availableBalance Decimal? @db.Decimal(14, 2)
  isoCurrencyCode  String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  transactions      Transaction[]
  balanceSnapshots  AccountBalanceSnapshot[]
  holdings          Holding[]

  @@index([itemId])
}

model Transaction {
  id                   String   @id @default(uuid(7)) @db.Uuid
  accountId            String   @db.Uuid
  account              Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  plaidTransactionId   String   @unique      // Plaid's transaction_id (upsert key)
  amount               Decimal  @db.Decimal(14, 2) // Plaid: positive = money out
  isoCurrencyCode      String?
  date                 DateTime @db.Date      // posted/authorized date
  authorizedDate       DateTime? @db.Date
  name                 String
  merchantName         String?

  // Plaid personal_finance_category
  pfcPrimary           String?
  pfcDetailed          String?

  pending              Boolean  @default(false)
  pendingTransactionId String?               // links a posted txn to its prior pending one
  paymentChannel       String?               // online | in store | other

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([accountId, date])
  @@index([date])
}

model AccountBalanceSnapshot {
  id        String  @id @default(uuid(7)) @db.Uuid
  accountId String  @db.Uuid
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  date             DateTime @db.Date // day this snapshot was taken
  currentBalance   Decimal  @db.Decimal(14, 2)
  availableBalance Decimal? @db.Decimal(14, 2)

  createdAt DateTime @default(now())

  @@unique([accountId, date])
  @@index([accountId])
}

// Global, shared reference data for a tradeable security - deliberately NOT
// userId-scoped (reference data has no tenant; two users holding AAPL share one
// row). Identity is (tickerSymbol, type) for tickered securities; tickerless
// ones (e.g. cash) fall back to Plaid's per-item security_id via
// plaidSecurityId. See issue #7.
model Security {
  id String @id @default(uuid(7)) @db.Uuid

  // Present for publicly-traded securities; null for tickerless ones (cash).
  tickerSymbol String?
  // Plaid security type: equity | etf | mutual fund | cash | fixed income | ...
  // Non-null so (tickerSymbol, type) is a well-formed compound unique;
  // defaults to "unknown" when Plaid can't classify the security.
  type String @default("unknown")

  // Only set for tickerless securities, where it is the fallback identity.
  // Left null for tickered securities (which dedupe on tickerSymbol+type), so
  // this unique index never collides across items sharing a ticker.
  plaidSecurityId String? @unique

  name String?

  // Latest close price given by Plaid; overwritten in place on each sync.
  closePrice      Decimal?  @db.Decimal(20, 8)
  closePriceAsOf  DateTime? @db.Date
  isoCurrencyCode String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  holdings Holding[]

  @@unique([tickerSymbol, type])
}

// A current-only snapshot of one account's position in one security. Reconciled
// on every sync (upserted, and deleted when Plaid stops returning it), so there
// is no history here. User-scoped transitively through Account -> PlaidItem.
model Holding {
  id String @id @default(uuid(7)) @db.Uuid

  accountId String  @db.Uuid
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  securityId String   @db.Uuid
  security   Security @relation(fields: [securityId], references: [id])

  quantity    Decimal  @db.Decimal(20, 8)
  costBasis   Decimal? @db.Decimal(20, 4)
  marketValue Decimal  @db.Decimal(20, 4) // Plaid institution_value
  price       Decimal  @db.Decimal(20, 8) // Plaid institution_price
  isoCurrencyCode String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([accountId, securityId])
  @@index([accountId])
  @@index([securityId])
}

enum PlaidPrimaryCategory {
  INCOME
  TRANSFER_IN
  TRANSFER_OUT
  LOAN_PAYMENTS
  BANK_FEES
  ENTERTAINMENT
  FOOD_AND_DRINK
  GENERAL_MERCHANDISE
  HOME_IMPROVEMENT
  MEDICAL
  PERSONAL_CARE
  GENERAL_SERVICES
  GOVERNMENT_AND_NON_PROFIT
  TRANSPORTATION
  TRAVEL
  RENT_AND_UTILITIES
}

// Who created a Goal/GoalContribution/Budget row - set once at creation and
// never changed afterward, even if the record is later edited by the other
// party. See docs/adr/0002-source-provenance-field-created-by-only.md.
enum Source {
  user
  agent
}

model Budget {
  id     String @id @default(uuid(7)) @db.Uuid
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  category      PlaidPrimaryCategory
  monthlyAmount Decimal              @db.Decimal(14, 2)
  effectiveFrom DateTime             @db.Date // budget applies from this date until a later effectiveFrom row for the same category supersedes it
  source        Source               @default(user)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, category, effectiveFrom])
  @@index([userId])
}

model Goal {
  id     String @id @default(uuid(7)) @db.Uuid
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name         String
  targetAmount Decimal   @db.Decimal(14, 2)
  targetDate   DateTime? @db.Date
  status       String    @default("active") // active | completed | archived
  source       Source    @default(user)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contributions GoalContribution[]

  @@index([userId])
}

model GoalContribution {
  id     String @id @default(uuid(7)) @db.Uuid
  goalId String @db.Uuid
  goal   Goal   @relation(fields: [goalId], references: [id], onDelete: Cascade)

  amount Decimal  @db.Decimal(14, 2)
  date   DateTime @db.Date
  note   String?
  source Source   @default(user)

  createdAt DateTime @default(now())

  @@index([goalId])
  @@index([goalId, date])
}